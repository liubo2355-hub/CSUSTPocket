<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvWeekPickerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择上课周次"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivWeekPickerClose"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="关闭"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_add_course_exit"
            android:tint="@color/color_icon_secondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvWeekPickerSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="可多选，支持快捷选择：全选 / 清空 / 单周 / 双周"
        android:textColor="@color/color_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvWeekPickerSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="已选 1 周"
        android:textColor="@color/color_text_functional"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:weightSum="4">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeekSelectAll"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="全选"
            android:textColor="@color/color_text_functional"
            android:textSize="13sp"
            app:backgroundTint="@color/color_bg_button_lowlight"
            app:cornerRadius="10dp"
            app:strokeColor="@color/color_outline_low_contrast"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeekClear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="清空"
            android:textColor="@color/color_text_functional"
            android:textSize="13sp"
            app:backgroundTint="@color/color_bg_button_lowlight"
            app:cornerRadius="10dp"
            app:strokeColor="@color/color_outline_low_contrast"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeekOdd"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="单周"
            android:textColor="@color/color_text_functional"
            android:textSize="13sp"
            app:backgroundTint="@color/color_bg_button_lowlight"
            app:cornerRadius="10dp"
            app:strokeColor="@color/color_outline_low_contrast"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeekEven"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="双周"
            android:textColor="@color/color_text_functional"
            android:textSize="13sp"
            app:backgroundTint="@color/color_bg_button_lowlight"
            app:cornerRadius="10dp"
            app:strokeColor="@color/color_outline_low_contrast"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWeeks"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeekCancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="取消"
            android:textColor="@color/color_text_secondary"
            app:backgroundTint="@color/color_bg_button_lowlight"
            app:cornerRadius="10dp"
            app:strokeColor="@color/color_outline_low_contrast"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeekConfirm"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:text="确定"
            android:textColor="@color/color_text_button"
            app:backgroundTint="@color/color_bg_button"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>