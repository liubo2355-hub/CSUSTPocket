<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/exam_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="166dp"
        android:layout_height="166dp"
        android:layout_gravity="center"
        android:background="@drawable/widget_card_background"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="11dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="考试安排"
                android:textColor="@color/widget_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/exam_widget_refresh"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/widget_refresh_background"
                android:contentDescription="刷新考试安排"
                android:padding="2dp"
                android:src="@drawable/widget_ic_refresh" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_exam_panel_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/exam_widget_badge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/widget_exam_icon_background"
                android:gravity="center"
                android:text="✓"
                android:textColor="@color/widget_pill_blue_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/exam_widget_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_pill_blue_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/exam_widget_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_subtitle"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/exam_widget_place"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_meta"
                    android:textSize="9.5sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
