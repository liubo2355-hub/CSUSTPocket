<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ele_widget_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="166dp"
        android:layout_height="166dp"
        android:layout_gravity="center"
        android:background="@drawable/widget_card_background"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="11dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="宿舍电量"
                    android:textColor="@color/widget_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/ele_widget_binding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_subtitle"
                    android:textSize="10sp"
                    tools:text="云塘校区 · 至诚轩 5 栋 A233" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/ele_widget_refresh"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/widget_refresh_background"
                android:contentDescription="刷新电量"
                android:padding="2dp"
                android:src="@drawable/widget_ic_refresh" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/ele_widget_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/widget_title"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    tools:text="30.34" />

                <TextView
                    android:id="@+id/ele_widget_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:layout_marginBottom="4dp"
                    android:text="kWh"
                    android:textColor="@color/widget_meta"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/ele_widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_status_background"
                android:paddingHorizontal="7dp"
                android:paddingVertical="1dp"
                android:text="电量正常"
                android:textColor="@color/widget_pill_blue_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/ele_widget_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:maxLines="1"
            android:textColor="@color/widget_subtitle"
            android:textSize="9.5sp"
            tools:text="已更新 · 刚刚" />
    </LinearLayout>
</FrameLayout>
