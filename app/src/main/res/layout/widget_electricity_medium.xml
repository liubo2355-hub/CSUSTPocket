<?xml version="1.0" encoding="utf-8"?>
<!-- 宿舍电量 · 中尺寸 (2x2 ≈ 180×180dp)
     当前电量 + 近 7 日折线图。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ele_widget_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="宿舍电量"
                android:textColor="@color/widget_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ele_widget_binding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/widget_subtitle"
                android:textSize="10.5sp"
                tools:text="云峰校区 · 5栋A区 233" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/ele_widget_refresh"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/widget_refresh_background"
            android:contentDescription="刷新电量"
            android:padding="6dp"
            android:src="@drawable/widget_ic_refresh" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/ele_widget_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="@color/widget_title"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="10.00" />

        <TextView
            android:id="@+id/ele_widget_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginBottom="3dp"
            android:text="kWh"
            android:textColor="@color/widget_meta"
            android:textSize="11sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/ele_widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_status_background"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="电量正常"
            android:textColor="@color/widget_pill_blue_text"
            android:textSize="9.5sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ele_widget_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:contentDescription="近七日电量"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/ele_widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_subtitle"
        android:textSize="10sp"
        tools:text="本地缓存 · 10:23" />
</LinearLayout>
