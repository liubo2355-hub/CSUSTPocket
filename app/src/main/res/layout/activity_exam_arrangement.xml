<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary"
    android:orientation="vertical">
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:background="@drawable/portal_toolbar_bg"
        android:layout_marginStart="@dimen/portal_card_margin_horizontal"
        android:layout_marginEnd="@dimen/portal_card_margin_horizontal"
        android:layout_marginTop="@dimen/portal_toolbar_margin_top"
        android:layout_marginBottom="@dimen/portal_toolbar_margin_bottom"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/binding_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_portal_back"
            android:contentDescription="返回"
            android:tint = "@color/color_title_top"/>

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="考试安排"
            android:textColor="@color/color_title_top"
            android:textSize="16sp"
            android:includeFontPadding="false"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/refresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="11dp"
            android:layout_gravity="center|end"
            android:layout_marginEnd="4dp"
            android:src="@drawable/shuaxin"
            android:tint = "@color/color_title_top"/>

    </LinearLayout>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="10dp"
            android:layout_height="match_parent"
            android:background="@color/color_bg_primary"
            android:paddingHorizontal="6dp"
            android:clipToPadding="false"/>

        <RelativeLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80FFFFFF"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:indeterminateTintMode="src_atop"
                android:indeterminateTint="@color/color_primary_blue"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/progressBar"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="加载中..."
                android:textColor="@color/color_primary_blue"
                android:textSize="14sp"/>

        </RelativeLayout>

    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:gravity="center"
        android:lineSpacingMultiplier="1.1"
        android:padding="@dimen/portal_card_padding_vertical"
        android:textSize="13sp"
        android:textColor="@color/color_text_grey"
        android:background="@drawable/bg_secondary"
        android:text="为防止网络波动优先读取上次查询缓存\n如有需要请及时点击刷新" />
</LinearLayout>
