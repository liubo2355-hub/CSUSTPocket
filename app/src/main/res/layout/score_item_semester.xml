<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="@dimen/portal_card_margin_vertical"
    app:cardBackgroundColor="@color/color_bg_card"
    android:orientation="vertical"
    app:cardCornerRadius="@dimen/portal_card_radius"
    app:cardElevation="@dimen/portal_card_elevation"
    app:strokeColor="@color/color_neum_highlight"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_bg_card"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/portal_card_padding_horizontal"
            android:paddingVertical="@dimen/portal_card_padding_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_semester_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2023-2024 第一学期"
                    android:textColor="@color/color_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_gpa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPA: 3.92"
                    android:textColor="@color/color_text_grey"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_expand"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_expand"
                android:tint = "@color/color_icon_secondary"/>

        </LinearLayout>
        <!-- 课程列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_courses"
            android:background="@color/color_bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
