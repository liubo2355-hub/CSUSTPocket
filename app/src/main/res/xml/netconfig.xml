<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 默认禁止明文 HTTP；Manifest 的 usesCleartextTraffic 会被本文件覆盖 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">user.csust.creamaker.cn</domain>
        <domain includeSubdomains="true">web.csust.creamaker.cn</domain>
        <domain includeSubdomains="true">pt.csust.edu.cn</domain>
        <domain includeSubdomains="true">authserver.csust.edu.cn</domain>
        <domain includeSubdomains="true">ehall.csust.edu.cn</domain>
        <!-- 教务系统 -->
        <domain includeSubdomains="true">xk.csust.edu.cn</domain>
        <!-- 评教系统：CAS 登录后由学校服务器重定向到 HTTP -->
        <domain includeSubdomains="true">zbxt.csust.edu.cn</domain>
        <!-- 校园卡系统 -->
        <domain includeSubdomains="true">yktwd.csust.edu.cn</domain>

        <domain includeSubdomains="true">ip-api.com</domain>
        <!-- 评论系统 -->
        <domain includeSubdomains="true">freshnews.csust.creamaker.cn</domain>
        <domain includeSubdomains="true">csust.creamaker.cn</domain>

        <!-- 预热请求 IP（PreRequestStartup） -->
        <domain includeSubdomains="false">113.44.47.220</domain>

        <!-- 高德轻量版 SDK：liteAmap.html 硬编码 http://webapi.amap.com/maps?... -->
        <domain includeSubdomains="true">amap.com</domain>
        <domain includeSubdomains="true">autonavi.com</domain>
        <domain includeSubdomains="true">alicdn.com</domain>
        <domain includeSubdomains="true">aliyuncs.com</domain>
    </domain-config>
</network-security-config>
