<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_BASIC_PHONE_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".core.PlanetApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:forceDarkAllowed="false"
        android:fullBackupContent="@xml/backup_rules"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/netconfig"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Changliplanetapp"
        android:usesCleartextTraffic="true"
        tools:replace="android:networkSecurityConfig"
        tools:targetApi="31">

        <!-- 高德地图 Android 轻量版 SDK Key（通过 manifestPlaceholders 从 local.properties 注入） -->
        <meta-data
            android:name="com.amap.api.v2.apikey"
            android:value="${amapApiKey}" />

        <activity
            android:name=".feature.common.ui.CalendarActivity"
            android:exported="false" />
        <activity
            android:name=".feature.calendar.ui.compose.SemesterCalendarDetailActivity"
            android:exported="false" />
        <activity
            android:name=".feature.mooc.ui.MoocActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mooc.ui.MoocCoursePageActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|uiMode|keyboardHidden|keyboard|locale|layoutDirection|fontScale|density"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".profileSettings.ui.AboutActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".common.ui.WebViewActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <receiver
            android:name=".TimeTableAppWidget"
            android:exported="true"
            android:label="@string/widget_timetable_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/time_table_app_widget_info" />
        </receiver>


        <receiver
            android:name=".ElectronicAppWidget"
            android:exported="true"
            android:label="@string/widget_electricity_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/electronic_app_widget_info" />
        </receiver>

        <receiver
            android:name=".ExamAppWidget"
            android:exported="true"
            android:label="@string/widget_exam_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/exam_app_widget_info" />
        </receiver>

        <receiver
            android:name=".GradeAppWidget"
            android:exported="true"
            android:label="@string/widget_grade_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/grade_app_widget_info" />
        </receiver>

        <service
            android:name=".common.service.DownloadService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name=".common.service.InstallCleanupReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".feature.common.ui.ContractActivity"
            android:exported="false" />
        <activity
            android:name=".feature.ledger.ui.FixSomethingAccountActivity"
            android:exported="false" />
        <activity
            android:name=".feature.ledger.ui.AddSomethingAccountActivity"
            android:exported="false" />
        <activity
            android:name=".feature.ledger.ui.AccountBookActivity"
            android:exported="false" />
        <activity
            android:name=".feature.common.ui.CampusMapActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|uiMode|keyboardHidden|keyboard|locale|layoutDirection|fontScale|density"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".base.FullScreenActivity"
            android:exported="false" />
        <activity
            android:name=".feature.common.ui.ClassInfoActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.common.ui.ScoreInquiryActivity"
            android:exported="false"
            android:screenOrientation="portrait" /> <!-- FileProvider 仍保留给其它文件分享场景使用 -->
        <activity
            android:name=".feature.common.ui.CourseDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.common.ui.ScoreExportActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.common.ui.ParityToolActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".profileSettings.ui.ParitySettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".profileSettings.ui.ProfileDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.physics.ui.PhysicsExperimentActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".feature.timetable.ui.TimeTableActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.ledger.ui.AddCourseActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".settings.ui.BindingUserActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.common.ui.MandeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.common.ui.CetActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:usesCleartextTraffic="true" />
        <activity
            android:name=".feature.common.ui.ExamArrangementActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".core.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".feature.common.ui.ElectronicActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".common.ui.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/SplashTheme">

            <!-- <intent-filter> -->
            <!-- <action android:name="android.intent.action.MAIN" /> -->


            <!-- <category android:name="android.intent.category.LAUNCHER" /> -->
            <!-- </intent-filter> -->
        </activity>
        <activity
            android:name=".skin.ui.SkinSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait">
        </activity>
    </application>

</manifest>
